# ---- Database (Postgres) ----
DATABASE_URL=postgres://user:password@localhost:5432/khaideestock

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs ต่อแพ็ก (Pro / Premium × รายเดือน/รายปี)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx
# (ค่าเก่า — ยังใช้เป็น fallback ของ Pro ได้)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=price_xxx
# บังคับแพ็กตอน local/ทดสอบ (free | pro | premium | enterprise)
# ⚠️ ห้ามตั้งใน production — จะ override แพ็กทุกร้านทั้งระบบ
DEV_PLAN=

# ---- Google Sign-In (OAuth 2.0) ----
# สร้างที่ https://console.cloud.google.com/apis/credentials → OAuth client ID (Web)
# Authorized redirect URI ต้องตรงกับ: <NEXT_PUBLIC_SITE_URL>/api/auth/google/callback
# เว้นว่างได้ — ปุ่ม Google จะถูกซ่อนอัตโนมัติถ้ายังไม่ได้ตั้งค่า
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- อีเมลระบบ (Gmail SMTP) ----
# ใช้ส่งอีเมลรีเซ็ตรหัสผ่าน ฯลฯ — สร้าง App Password ที่ https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ---- App ----
# production ต้องตั้งเป็นโดเมนจริงเสมอ (fallback คือ localhost)
NEXT_PUBLIC_SITE_URL=http://localhost:3020
COOKIE_SECURE=false   # true เฉพาะตอน deploy บน HTTPS จริง

# ---- Admin dashboard (/admin) ----
# อีเมลที่เข้าหน้าผู้ดูแลระบบได้ (คั่นด้วย comma) — เว้นว่าง = ปิดระบบ admin
ADMIN_EMAILS=
